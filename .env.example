# Copy this file to ".env" and fill in your Personio API credentials.
# ".env" is gitignored so your secret is never committed.
#
# Get these from Personio: Settings > Integrations > API credentials >
# Generate new credentials (READ access to Employees).
#
# Then set `use_mock_data: false` in config.yaml and run: python run_export.py

PERSONIO_CLIENT_ID=""
PERSONIO_CLIENT_SECRET=""

# Optional - only change if Personio told you to use a different host.
# PERSONIO_BASE_URL="https://api.personio.de"

# Optional - password for SFTP delivery (delivery.type: sftp in config.yaml).
# PERSONIO_SFTP_PASSWORD=""
